{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUnusedLocals": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node", "electron"]
  },
  "include": ["electron/**/*.ts", "electron.vite.config.ts"]
}
